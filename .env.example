# Dondabazza (돈다바짜) — Backend Environment Variables 
# 사용법: 이 파일을 프로젝트 루트에 .env 로 복사 후 값 채우기
#   cp .env.example .env

# Supabase PostgreSQL 연결 문자열 (Transaction Pooler, sync/psycopg2 드라이버)
# 형식: postgresql://<user>:<password>@<host>:<port>/<db>
DB_DSN=postgresql://<user>:<password>@<host>:6543/postgres

# Supabase 프로젝트 URL (JWT 검증용 JWKS 엔드포인트의 베이스 URL)
# Supabase 대시보드 > Project Settings > API 에서 확인
SUPABASE_URL=https://<your-project-ref>.supabase.co

# 프론트엔드 개발 서버에서의 CORS 허용 origin (콤마로 구분)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 아래는 etl/ 파이프라인을 직접 실행할 경우에만 필요 (선택) 
# LLM 정규화(etl/transform/llm_normalizer.py)에 사용하는 API 키
LLM_API_KEY=<your_llm_api_key>